resources:
  jobs:
    Sales_ETL_pipeline:
      name: Sales ETL pipeline
      tasks:
        - task_key: Ingest_raw_data
          notebook_task:
            notebook_path: Notebooks/Ingest Data - Bronze layer
            source: GIT
        - task_key: Clean_and_transform
          depends_on:
            - task_key: Ingest_raw_data
          notebook_task:
            notebook_path: Notebooks/Transformation and cleaning - Silver Layer
            source: GIT
        - task_key: Data_Quality_Checks
          depends_on:
            - task_key: Clean_and_transform
          notebook_task:
            notebook_path: Notebooks/Data Quality Checks
            source: GIT
        - task_key: tables
          depends_on:
            - task_key: Clean_and_transform
          notebook_task:
            notebook_path: Notebooks/Tables - fact & dimension
            source: GIT
        - task_key: analytics_layer
          depends_on:
            - task_key: Clean_and_transform
          notebook_task:
            notebook_path: Notebooks/Aggregate Tables - Gold Layer
            source: GIT
      git_source:
        git_url: https://github.com/harshitadhiman/databricks-sales-pipeline.git
        git_provider: github
        git_branch: main
      queue:
        enabled: true
      performance_target: PERFORMANCE_OPTIMIZED
